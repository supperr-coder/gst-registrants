# Copy this file to .env and fill in your values
# Do NOT commit .env to version control

# --- MAESTRO (indexing + SageMaker endpoint) ---
# Only needed when running indexing or the SageMaker endpoint on MAESTRO
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://your-maestro-litellm-proxy-url/v1

# S3 (usually not needed on SageMaker — IAM role handles auth)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=ap-southeast-1

# --- Airbase (Streamlit frontend) ---
# Only needed when running the Streamlit app (locally or on Airbase)
SAGEMAKER_ENDPOINT_URL=https://your-maestro-api-gateway-url
SAGEMAKER_API_KEY=your-maestro-api-gateway-key
